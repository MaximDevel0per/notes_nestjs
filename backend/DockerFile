FROM node:22-alpine
WORKDIR /usr/local/app

# Abhängigkeiten (reproduzierbar über den Lockfile)
COPY package.json package-lock.json ./
RUN npm ci

# Quellcode + Build
COPY tsconfig.json nest-cli.json ./
COPY src ./src
RUN npm run build && npm prune --omit=dev

EXPOSE 3000
USER node

CMD ["node", "dist/main.js"]